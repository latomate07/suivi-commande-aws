# Configuration Cognito / API pour le dev local.
# Copier ce fichier en .env.local et renseigner les valeurs réelles
# (voir les Outputs CloudFormation du stack : AdminUserPoolId, AdminUserPoolClientId, AdminApiUrl).
# En CI/déploiement, ces variables sont injectées automatiquement par le workflow.

# User Pool Cognito (contient la région, ex. eu-west-1_ABC123456)
VITE_COGNITO_USER_POOL_ID=

# App client Cognito (sans secret)
VITE_COGNITO_CLIENT_ID=

# URL de base de l'API admin protégée par Cognito
VITE_ADMIN_API_URL=https://f65g4wie3i.execute-api.eu-west-1.amazonaws.com/dev
